{
  "name": "virtual-file-explorer",
  "version": "0.1.0",
  "description": "Explorer and workflow framework for flat Obsidian vaults powered by frontmatter categories.",
  "main": "main.js",
  "packageManager": "bun@1.3.11",
  "scripts": {
    "dev": "bun esbuild.config.mjs",
    "build": "tsc --noEmit --skipLibCheck && bun esbuild.config.mjs production"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "categories",
    "explorer"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.30",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.25.2",
    "obsidian": "^1.8.7",
    "typescript": "^5.8.3"
  }
}
